# Copy to .env and fill in your actual values
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx

# Aiven MySQL (same DB as your LMS is fine — tables are vyom_ prefixed)
DATABASE_URL=mysql+pymysql://avnadmin:PASSWORD@HOST.aivencloud.com:PORT/defaultdb?ssl_ca=/path/to/ca.pem

# CORS — your Netlify frontend origin(s)
ALLOWED_ORIGINS=https://vyom.upskillize.com,https://lms.upskillize.com,http://localhost:5173

# Reuse your LMS JWT secret (so a login on LMS works on Vyom automatically)
JWT_SECRET=same-secret-as-your-lms
JWT_ALGORITHM=HS256

# Rate limits
MAX_SESSIONS_PER_DAY=10

# Model choices (cost optimization: Haiku for turns, Sonnet for debrief)
MODEL_INTERVIEW=claude-haiku-4-5-20251001
MODEL_DEBRIEF=claude-sonnet-4-6

# ── Phase D: presence metrics m1–m8 (on-device expression/posture) ──
# SHIPS DARK. Leave false until the camera/attention-cue consent block has cleared LEGAL
# review. With it false the feature is built but inert: /session/presence 404s, the client
# never loads MediaPipe, and no metric is computed, stored, or shown. Report-only, VIDEO
# mode only — flipping this changes no score and no band. Needs migration 010 applied and
# the self-hosted MediaPipe assets in place (scripts/fetch_mediapipe_assets.mjs) first.
PRESENCE_METRICS_ENABLED=false
