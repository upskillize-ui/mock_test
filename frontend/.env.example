# API base URL for the frontend.
# Leave EMPTY for a same-origin deploy (Docker / Hugging Face Space serves API + UI together).
# Set to the full backend origin for a split deploy (e.g. Netlify UI -> Render API).
# Either name works; VITE_INTERVIEWIQ_API_URL takes precedence over VITE_API_URL.
VITE_INTERVIEWIQ_API_URL=
# VITE_API_URL=https://your-backend.onrender.com

# Phase D presence metrics (on-device m1–m8). SHIPS DARK — leave unset/off until the
# camera/attention-cue consent block clears legal review. Off = MediaPipe is never
# imported and not a frame is processed. Report-only; never affects a score.
# VITE_PRESENCE_METRICS=on
